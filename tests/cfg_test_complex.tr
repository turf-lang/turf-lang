// Test: Complex control flow with loops and conditionals
// Expected: Should handle nested loops and branches correctly

fn int test_complex(int n) {
    int result = 0
    int i = 0
    
    while (i < n) {
        if (i % 2 == 0) {
            result = result + i
        } else {
            result = result - i
        }
        
        if (result > 100) {
            break
        } else {
            i = i + 1
        }
    }
    
    return result
}

// Top-level call
test_complex(20)
