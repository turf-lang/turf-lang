// cascade_errors.tr
// Demonstrates cascading error suppression.
// Expected: two errors (line 4 and line 7), NOT just the first.
// Line 9 is valid and would compile cleanly on its own.

// Error 1: undeclared variable on the RHS
int a = badVar

// Error 2: type mismatch (completely independent root cause)
string s = 42

// Valid statement after the errors, should be parsed without issue
int valid = 10
print(valid)
