// Test: Break and continue in same loop
// Expected: Should compile successfully

fn int test_break_and_continue(int n) {
    int i = 0
    int sum = 0
    
    while (i < n) {
        i = i + 1
        
        if (i % 5 == 0) {
            continue
        } else {
            if (i > n / 2) {
                break
            } else {
                sum = sum + i
            }
        }
    }
    
    return sum
}

// Top-level call
test_break_and_continue(20)
