// =============================================
// Lint Warning Test Suite
// Each section triggers one specific warning.
// The file should compile successfully with
// warnings printed to stderr.
// =============================================

// --- Test 1: Redundant comparison (== true) ---
bool myFlag = true
bool check1 = myFlag == true

// --- Test 2: Redundant comparison (!= false) ---
bool check2 = myFlag != false

// --- Test 3: Self-assignment (x = x) ---
int x = 42
x = x

// --- Test 4: Infinite loop (while true, no exit) ---
// NOTE: Commented out because it would loop forever at runtime.
// The compiler should WARN about it during compilation.
// Uncomment to verify the warning fires:
// while true {
//   int dummy = 1
// }

// --- Test 5: Empty then branch ---
// Use block-style if (no 'then' keyword) for empty branches.
int y = 10
if y > 5 {
} else {

  y = 1
}

// --- Test 6: Empty else branch ---
if y > 5 {
  y = 2
} else {
}

// --- Test 7: Self-comparison (x == x) ---
bool same = x == x

// --- Test 8: Self-comparison (x != x, always false) ---
bool diff = x != x


// --- Test 9: Division by zero literal ---
int z = 10
int bad_div = z / 0


// --- Test 10: Modulo by zero literal ---
int bad_mod = z % 0


// --- Test 11: Identical branches ---
int val = 100
int result = if val > 50 then 42 else 42

// --- Test 12: while(true) WITH break (should NOT warn) ---
int counter = 0
while true {
  counter++
  if counter > 3 {
    break
  } else {
  }
}

// --- Test 13: Normal comparison (should NOT warn) ---
bool normal = x == y

// --- Test 14: Normal assignment (should NOT warn) ---
x = y

// Print results to verify compilation succeeded
printline(check1)

printline(check2)
printline(x)
printline(y)

printline(same)
printline(diff)
printline(result)
printline(counter)
printline(normal)
