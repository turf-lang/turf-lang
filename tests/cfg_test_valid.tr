// Test: Valid control flow with all paths returning
// Expected: Should compile successfully with no warnings

fn int test_all_paths(int x) {
    if (x > 0) {
        return x * 2
    } else {
        return x * 3
    }
}

fn int test_nested(int a) {
    if (a > 10) {
        if (a > 20) {
            return a + 5
        } else {
            return a + 3
        }
    } else {
        return a + 1
    }
}

// Top-level calls
int result = test_all_paths(5)
result = result + test_nested(15)
