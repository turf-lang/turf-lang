// loop_test.tr
// Tests break and continue in Turf

printline(add(1, 2));

int i = 0
int sum = 0

// Test continue
while i < 10 {
  i++
  if i % 2 == 0 {
    continue
  } else {}
  sum += i
}
printline(sum) // 1 + 3 + 5 + 7 + 9 = 25

i = 0
sum = 0
// Test break
while i < 10 {
  i++
  if i > 5 {
    break
  } else {}
  sum += i
}
printline(sum) // 1 + 2 + 3 + 4 + 5 = 15

fn int add(int a, int b) {
  return a + b
}