// 2D Array with initializers
int[2][3] grid = [
    [1, 2, 3],
    [4, 5, 6]
];

print("Grid check:");
print(string(grid[0][0])); // Expect 1
print(string(grid[0][1])); // Expect 2
print(string(grid[1][2])); // Expect 6

// 3D Array with initializers
int[2][2][2] cube = [
    [
        [10, 20],
        [30, 40]
    ],
    [
        [50, 60],
        [70, 80]
    ]
];

print("Cube check:");
print(string(cube[0][0][0])); // Expect 10
print(string(cube[0][1][1])); // Expect 40
print(string(cube[1][0][0])); // Expect 50
print(string(cube[1][1][1])); // Expect 80
