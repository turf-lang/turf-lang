// Test 1: Non-void function missing return (should error)
fn int missing_return(int x) {
    if x > 0 {
        print("positive")
    } else {}
}

// Test 2: Non-void function with return on all paths (should work)
fn int all_paths_return(int x) {
    if x > 0 {
        return 1
    } else {
        return 0
    }
}

// Test 3: Void function with no return (should work)
fn void no_return_needed() {
    print("hello")
}

// Test 4: Void function with empty return (should work)
fn void empty_return() {
    return;
}

// Test 5: Void function returning value (should error)
fn void void_with_value() {
    return 5
}

// Test 6: Non-void function with empty return (should error)
fn int non_void_empty_return() {
    return;
}

printline(all_paths_return(1))
