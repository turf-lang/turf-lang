// Test: Continue in nested loop structure
// Expected: Should compile successfully

fn int test_nested_continue(int n) {
    int i = 0
    int count = 0
    
    while (i < n) {
        i = i + 1
        
        if (i % 2 == 0) {
            continue
        } else {
            count = count + 1
        }
    }
    
    return count
}

// Top-level call
test_nested_continue(10)
