// Test: Dead code after continue in loop
// Expected: Should detect unreachable code after continue

fn int test_continue() {
    int sum = 0
    int i = 0
    while (i < 10) {
        i = i + 1
        if (i == 5) {
            continue
            sum = sum + 100  // Unreachable after continue
        } else {
            sum = sum + i
        }
    }
    return sum
}

// Top-level call
test_continue()
