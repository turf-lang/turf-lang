// Test: Return inside nested block
// Expected: Should detect unreachable code

fn int test_nested_block_return() {
    if (true) {
        if (true) {
            return 5
            int x = 10  // Unreachable
        } else {
            int dummy = 0
        }
    } else {
        int dummy = 0
    }
    return 0
}

// Top-level call
test_nested_block_return()
