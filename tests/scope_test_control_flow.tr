// Test 6: Complex scope test with control flow

int x = 1;

if x > 0 {
  int y = 2;
  print(x);
  print(y);
} else {
  int y = 3;  // Different scope from then-branch (should not error)
  print(x);
  print(y);
}

// y is not accessible here (would error if used)

int counter = 0;
while counter < 3 {
  int loopVar = counter * 2;
  print(loopVar);
  counter = counter + 1;
}

// loopVar is not accessible here (would error if used)
print(counter);
